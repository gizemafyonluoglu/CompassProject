<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<VBox alignment="CENTER" spacing="15" prefWidth="400" prefHeight="350"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #ddd; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.compass.demo1.ActivityDetailController">

    <Label text="Activity Details" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #8A2BE2;" />

    <StackPane>
        <Circle fx:id="profileCircle" radius="40" fill="#F3E5F5" stroke="#8A2BE2" strokeWidth="1" />
        <ImageView fx:id="profileImage" fitHeight="80" fitWidth="80">
            <clip>
                <Circle centerX="40" centerY="40" radius="40" />
            </clip>
        </ImageView>
    </StackPane>

    <Label fx:id="nameLabel" text="İsim Soyisim" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

    <VBox alignment="TOP_LEFT" style="-fx-background-color: #F8F4FF; -fx-background-radius: 10; -fx-padding: 10;">
        <Label text="Description:" style="-fx-font-weight: bold; -fx-text-fill: #8A2BE2;" />
        <Label fx:id="descriptionLabel" text="Burada aktivite açıklaması yer alacak..." wrapText="true" style="-fx-text-fill: #555;" />
    </VBox>

    <Button text="Close" onAction="#handleClose"
            style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 8 40; -fx-cursor: hand;" />

</VBox>