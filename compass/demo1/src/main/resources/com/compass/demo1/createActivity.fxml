<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.compass.demo1.CreateActivityController"
           stylesheets="@style.css">

    <children>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F3F4F6; -fx-background: #F3F4F6; -fx-border-color: transparent;">
            <content>
                <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-padding: 30 0;">
                    <children>

                        <VBox maxWidth="560.0" spacing="12.0" styleClass="card">
                            <padding>
                                <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
                            </padding>

                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Create Activity" styleClass="label-title"/>
                                    </children>
                                </HBox>

                                <VBox spacing="8.0">
                                    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #F8F9FA; -fx-padding: 10 20; -fx-background-radius: 12;">
                                        <Label text="Public" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                        <CheckBox fx:id="switchVisibility" styleClass="ios-switch" />
                                        <Label text="Friends Only" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="8.0">
                                    <HBox fx:id="typeToggleContainer" alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #F8F9FA; -fx-padding: 10 20; -fx-background-radius: 12;">
                                        <Label text="Regular Activity" style="-fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                                        <CheckBox fx:id="switchType" styleClass="ios-switch" />
                                        <Label text="Club Activity" style="-fx-font-weight: bold; -fx-text-fill: #8A2BE2;"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="6.0">
                                    <Label text="Category" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="inpCategory" editable="false" onMouseClicked="#showCategoryPopup" promptText="Select categories..." styleClass="text-field" style="-fx-cursor: hand;" />
                                </VBox>

                                <VBox spacing="6.0">
                                    <Label text="Activity Name" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="inpName" promptText="Enter activity name" styleClass="text-field"/>
                                </VBox>

                                <VBox spacing="6.0">
                                    <Label text="Description" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="inpDesc" promptText="Short description" styleClass="text-field"/>
                                </VBox>

                                <VBox spacing="6.0">
                                    <Label text="Place" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="inpPlace" promptText="Enter place" styleClass="text-field"/>
                                </VBox>

                                <HBox spacing="14.0">
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label text="Date" style="-fx-font-weight: bold;"/>
                                        <DatePicker fx:id="datePicker" maxWidth="Infinity"/>
                                    </VBox>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label text="Time" style="-fx-font-weight: bold;"/>
                                        <TextField fx:id="inpTime" promptText="14:00" styleClass="text-field"/>
                                    </VBox>
                                </HBox>

                                <VBox spacing="6.0">
                                    <Label text="Quota" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="inpQuota" promptText="Enter participant limit" styleClass="text-field"/>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT" spacing="12.0" style="-fx-padding: 10 0 0 0;">
                                    <Button text="Cancel" onAction="#handleCancel"
                                            style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;"
                                            prefWidth="100.0"/>
                                    <Button text="Create" onAction="#handleSubmit"
                                            styleClass="button-primary" prefWidth="120.0"/>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <Pane fx:id="overlay" onMouseClicked="#hideCategoryPopup" style="-fx-background-color: rgba(0,0,0,0.5);" visible="false" />

        <VBox fx:id="categoryPopup" maxWidth="550.0" spacing="20.0" styleClass="card" visible="false" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 15, 0, 0, 5);">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
            <children>
                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Select Categories" />
                <FlowPane hgap="12.0" vgap="12.0" alignment="CENTER">
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Music" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Arts" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Gaming" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Movies" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Writing" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Food &amp; Cooking" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Travel" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Engineering" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Philosophy" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Psychology" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Economics" prefWidth="140" />
                    <Button onAction="#toggleCategory" styleClass="interest-button" text="Mathematics" prefWidth="140" />
                </FlowPane>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Button onAction="#hideCategoryPopup" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-radius: 10; -fx-text-fill: #475569; -fx-padding: 8 20; -fx-cursor: hand;" text="Cancel" />
                    <Button onAction="#confirmCategories" style="-fx-background-color: #8A2BE2; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 25; -fx-cursor: hand;" text="OK" />
                </HBox>
            </children>
        </VBox>

        <VBox fx:id="errorPopup" maxWidth="400.0" spacing="20.0" styleClass="card" visible="false"
              alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 20, 0, 0, 10);">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
            <children>
                <Label text="⚠️" style="-fx-font-size: 40;" />
                <Label text="Hata!" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #EF4444;" />
                <Label fx:id="lblErrorMessage" text="Please fill in all the fields!"
                       wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #475569; -fx-font-size: 14;" />
                <Button text="OKAY" onAction="#hideErrorPopup"
                        style="-fx-background-color: #8A2BE2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 40; -fx-cursor: hand;" />
            </children>
        </VBox>
    </children>
</StackPane>