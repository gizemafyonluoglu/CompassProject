<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="600.0" prefWidth="900.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.compass.demo1.CalendarController">
    <children>
        <BorderPane>
            <left>
                <VBox alignment="TOP_CENTER" prefWidth="80.0" spacing="20.0" style="-fx-background-color: #F8F9FA; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;">
                    <padding><Insets top="30.0" /></padding>
                    <children>
                        <Button onAction="#goToProfile" styleClass="sidebar-button">
                            <graphic><ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@icons/profile.png" /></image></ImageView></graphic>
                        </Button>
                        <Button onAction="#goToFriend" styleClass="sidebar-button">
                            <graphic><ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@icons/friend.png" /></image></ImageView></graphic>
                        </Button>
                        <Button onAction="#goToHome" styleClass="sidebar-button">
                            <graphic><ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@icons/home.png" /></image></ImageView></graphic>
                        </Button>
                        <Button onAction="#goToActivities" styleClass="sidebar-button">
                            <graphic><ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@icons/activity.png" /></image></ImageView></graphic>
                        </Button>
                        <Button styleClass="sidebar-button-active">
                            <graphic><ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@icons/calendar.png" /></image></ImageView></graphic>
                        </Button>
                    </children>
                </VBox>
            </left>

            <center>
                <VBox fx:id="mainContentArea" spacing="20.0" style="-fx-background-color: white;">
                    <padding><Insets bottom="20.0" left="40.0" right="30.0" top="30.0" /></padding>
                    <children>

                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="pageTitle" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #8A2BE2; -fx-underline: true;" text="Weekly Plan" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox spacing="15.0">
                                <Button onAction="#showAddPlanPopup" styleClass="button-primary" text="+ Add Plan" />
                                <Button fx:id="modeBtn" onAction="#toggleMode" styleClass="btn-mode" text="☼ Day Mode (8:00 - 18:00)" />
                            </HBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <HBox alignment="CENTER_LEFT" spacing="5"><Region prefHeight="15" prefWidth="15" style="-fx-background-color: #3B82F6; -fx-background-radius: 3;" /><Label fx:id="lblCourse" style="-fx-font-weight: bold;" text="Course" /></HBox>
                            <HBox alignment="CENTER_LEFT" spacing="5"><Region prefHeight="15" prefWidth="15" style="-fx-background-color: #EF4444; -fx-background-radius: 3;" /><Label fx:id="lblPerm" style="-fx-font-weight: bold;" text="Permanent Event" /></HBox>
                            <HBox alignment="CENTER_LEFT" spacing="5"><Region prefHeight="15" prefWidth="15" style="-fx-background-color: #F97316; -fx-background-radius: 3;" /><Label fx:id="lblOneTime" style="-fx-font-weight: bold;" text="One-time Event" /></HBox>
                        </HBox>

                        <HBox fx:id="daysHeader" spacing="0">
                            <padding><Insets left="60.0" /></padding> </HBox>

                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <StackPane alignment="TOP_LEFT">
                                    <VBox fx:id="calendarGrid" spacing="0" />
                                    <Pane fx:id="eventsOverlay" />
                                </StackPane>
                            </content>
                        </ScrollPane>

                    </children>
                </VBox>
            </center>
        </BorderPane>

        <Pane fx:id="overlay" onMouseClicked="#hidePopup" style="-fx-background-color: rgba(0,0,0,0.5);" visible="false" />

        <VBox fx:id="addPlanPopup" maxHeight="-Infinity" maxWidth="400.0" spacing="15.0" styleClass="card" visible="false">
            <padding><Insets bottom="25.0" left="30.0" right="30.0" top="25.0" /></padding>
            <children>
                <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #8A2BE2;" text="Add New Plan" />

                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold;" text="Plan Name" />
                    <TextField fx:id="inpName" promptText=" " styleClass="profile-field-box" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold;" text="Day" />
                    <ComboBox fx:id="cmbDay" maxWidth="Infinity" promptText="Thu" styleClass="profile-field-box" />
                </VBox>

                <HBox spacing="15">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-weight: bold;" text="Start Time" />
                        <TextField fx:id="inpStart" promptText="11:30" styleClass="profile-field-box" />
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label style="-fx-font-weight: bold;" text="End Time" />
                        <TextField fx:id="inpEnd" promptText="12:30" styleClass="profile-field-box" />
                    </VBox>
                </HBox>

                <VBox spacing="10">
                    <Label style="-fx-font-weight: bold;" text="Plan Type" />
                    <HBox spacing="15">
                        <RadioButton fx:id="rbCourse" selected="true" text="Course" />
                        <RadioButton fx:id="rbPerm" text="Permanent" />
                        <RadioButton fx:id="rbOneTime" text="One-time" />
                    </HBox>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <padding><Insets top="10" /></padding>
                    <Button onAction="#hidePopup" styleClass="button-secondary" text="Cancel" />
                    <Button onAction="#addNewPlan" styleClass="button-primary" text="Add Plan" />
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
